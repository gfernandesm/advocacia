# Claude API (obrigatório)
ANTHROPIC_API_KEY=sk-ant-...

# Identificador do cliente (define qual config carregar)
# Valor padrão: "template" — usa a config base
CLIENTE_ID=template

# Login do advogado (obrigatório)
AUTH_EMAIL=advogado@email.com
AUTH_PASSWORD=senha-segura-aqui
AUTH_SECRET=gere-uma-string-aleatoria-longa-aqui

# Supabase (opcional — necessário apenas se adicionar banco)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
